# ── SAQ Digital Solutions — конфигурация ──
# Скопируйте этот файл в .env и заполните значения.

# Порт сервера
PORT=3000

# ── Уведомления о заявках (включаются по мере заполнения) ──

# Telegram-бот. Получить токен: напишите @BotFather → /newbot.
# Узнать chat_id: после заполнения токена запустите `npm run tg:chatid`,
# затем проверьте отправку: `npm run tg:test`.
#
# Личный чат: напишите боту /start и любое сообщение → tg:chatid покажет id.
# Группа: добавьте бота в группу → tg:chatid покажет её id (он ОТРИЦАТЕЛЬНЫЙ,
#   напр. -1001234567890). Если не показал — упомяните бота в группе (@имя_бота)
#   или отключите приватный режим у @BotFather (/setprivacy → Disable) и повторите.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Тема (Topic) супергруппы — если хотите писать в конкретную тему, напр. «Leads».
# Напишите сообщение в нужной теме → `npm run tg:chatid` покажет её id.
# Оставьте пустым, чтобы писать в общий чат группы.
TELEGRAM_TOPIC_ID=

# Email через SMTP (опционально). Если хотите письма на почту —
# заполните и установите nodemailer (npm i nodemailer).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
LEAD_EMAIL_TO=malayevyerkanat@gmail.com

# ── Админка заявок ──
# Пароль для входа на /admin (просмотр всех заявок). Если пусто — админка выключена.
ADMIN_PASSWORD=
